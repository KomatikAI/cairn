{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false
  },
  "providers": {
    "openrouter": {
      "network_config": {
        "default_request_timeout_in_seconds": 180
      },
      "keys": [
        {
          "name": "openrouter-dry-run",
          "value": "${OPENROUTER_API_KEY}",
          "models": ["*"],
          "weight": 1.0
        }
      ]
    }
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./data/config.db"
    }
  }
}
