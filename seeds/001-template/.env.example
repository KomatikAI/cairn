# Seed 001 Template Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL Configuration
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Bifrost Configuration (LLM Provider API Keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Seed Virtual Key (for Bifrost metering)
SEED_VIRTUAL_KEY=svk-template-dryrun

# GitHub Configuration (for Publisher)
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=komatik/cairn

# Optional: Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Seed Configuration
SEED_NAME=Template
SEED_DIR=seeds/001-template
CATEGORY_ID=your_category_id_here
ROOT_ID=your_root_id_here
SOURCE_ID=your_source_id_here

# Scheduler Configuration
CYCLE_INTERVAL=3600  # Seconds between cycles (default: 1 hour)

# Gateway Configuration
GATEWAY_PORT=4000
